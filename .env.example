# URL the landing's CTAs ("Start chatting", "Build a room") link to.
# In production this is your hosted wwxd instance. In dev you can point at
# `http://localhost:3000` if you're running the wwxd app side-by-side.
NEXT_PUBLIC_APP_URL=https://app.wwxd.chat

# GitHub repo URL the GitHub buttons link to.
NEXT_PUBLIC_GITHUB_URL=https://github.com/wwxd/wwxd
